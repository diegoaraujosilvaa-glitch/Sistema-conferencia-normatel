{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["CONFERENTE", "SUPERVISOR", "ADMIN"] },
        "password": { "type": "string" }
      },
      "required": ["id", "name", "username", "role"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Company branch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cnpj": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "cnpj", "name"]
    },
    "ConferenceBatch": {
      "title": "ConferenceBatch",
      "description": "A batch of NFe products for conference",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "notes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "number": { "type": "string" },
              "accessKey": { "type": "string" },
              "vendorCnpj": { "type": "string" },
              "vendorName": { "type": "string" },
              "emissionDate": { "type": "string" }
            }
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "code": { "type": "string" },
              "ean": { "type": "string" },
              "description": { "type": "string" },
              "quantityExpected": { "type": "number" },
              "quantityChecked": { "type": "number" }
            }
          }
        },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "PENDING_SUPERVISOR", "APPROVED", "REJECTED"] },
        "conferenteId": { "type": "string" },
        "conferenteName": { "type": "string" },
        "supervisorId": { "type": "string" },
        "supervisorName": { "type": "string" },
        "justification": { "type": "string" }
      },
      "required": ["id", "notes", "products", "startTime", "status", "conferenteId", "conferenteName"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "branches": {
      "schema": "Branch",
      "description": "Collection of company branches"
    },
    "batches": {
      "schema": "ConferenceBatch",
      "description": "Collection of conference batches"
    },
    "pausedBatches": {
      "schema": "ConferenceBatch",
      "description": "Collection of paused conference batches"
    },
    "currentBatches": {
      "schema": "ConferenceBatch",
      "description": "Active batch per user, keyed by userId"
    }
  }
}
